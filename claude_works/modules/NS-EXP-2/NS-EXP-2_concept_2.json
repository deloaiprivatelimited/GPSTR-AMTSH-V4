  "theory": {
    "concept_summary": "ಘಾತಾಂಕ ರೂಪದಲ್ಲಿರುವ ಸಂಖ್ಯೆಗಳ ಮೇಲಿನ ಗಣಿತದ ಕ್ರಿಯೆಗಳನ್ನು (ಗುಣಾಕಾರ, ಭಾಗಾಕಾರ) ಸುಲಭಗೊಳಿಸಲು ಕೆಲವು ನಿರ್ದಿಷ್ಟ ನಿಯಮಗಳಿವೆ. ಈ ನಿಯಮಗಳು ಒಂದೇ ಆಧಾರ ಅಥವಾ ಒಂದೇ ಘಾತಸೂಚಿಯನ್ನು ಹೊಂದಿರುವ ಪದಗಳಿಗೆ ಅನ್ವಯಿಸುತ್ತವೆ ಮತ್ತು ಧನ, ಋಣ ಹಾಗೂ ಶೂನ್ಯ ಪೂರ್ಣಾಂಕ ಘಾತಸೂಚಿಗಳಿಗೆ ಸಿಂಧುವಾಗಿವೆ.",
    "definitions": [],
    "formulas": [
      {
        "formula_name": "product_rule_same_base",
        "latex": "$$a^m \\times a^n = a^{m+n}$$",
        "condition": "'a' ಸೊನ್ನೆಯಲ್ಲದ ಯಾವುದೇ ಪೂರ್ಣಾಂಕ, 'm' ಮತ್ತು 'n' ಯಾವುದೇ ಪೂರ್ಣಾಂಕಗಳು.",
        "exception": "",
        "derived_from": "",
        "used_in": "ಒಂದೇ ಆಧಾರವಿರುವ ಘಾತಗಳನ್ನು ಗುಣಿಸುವಾಗ.",
        "derivation": []
      },
      {
        "formula_name": "quotient_rule_same_base",
        "latex": "$$a^m \\div a^n = \\frac{a^m}{a^n} = a^{m-n}$$",
        "condition": "'a' ಸೊನ್ನೆಯಲ್ಲದ ಯಾವುದೇ ಪೂರ್ಣಾಂಕ, 'm' ಮತ್ತು 'n' ಯಾವುದೇ ಪೂರ್ಣಾಂಕಗಳು.",
        "exception": "",
        "derived_from": "",
        "used_in": "ಒಂದೇ ಆಧಾರವಿರುವ ಘಾತಗಳನ್ನು ಭಾಗಿಸುವಾಗ.",
        "derivation": []
      },
      {
        "formula_name": "power_of_a_power_rule",
        "latex": "$$(a^m)^n = a^{mn}$$",
        "condition": "'a' ಸೊನ್ನೆಯಲ್ಲದ ಯಾವುದೇ ಪೂರ್ಣಾಂಕ, 'm' ಮತ್ತು 'n' ಯಾವುದೇ ಪೂರ್ಣಾಂಕಗಳು.",
        "exception": "",
        "derived_from": "",
        "used_in": "ಒಂದು ಘಾತಕ್ಕೆ ಮತ್ತೊಂದು ಘಾತವನ್ನು ಅನ್ವಯಿಸಿದಾಗ.",
        "derivation": []
