  "theory": {
    "concept_summary": "$x^2 + px + q$ ರೂಪದ ತ್ರಿಪದಗಳನ್ನು (trinomials) ಅಪವರ್ತಿಸಲು, ನಾವು $q$ ನ ಎರಡು ಅಪವರ್ತನಗಳನ್ನು (a ಮತ್ತು b) ಕಂಡುಹಿಡಿಯಬೇಕು, ಆ ಅಪವರ್ತನಗಳ ಮೊತ್ತವು $x$ ನ ಸಹಗುಣಕವಾದ $p$ ಗೆ ಸಮನಾಗಿರಬೇಕು. ಅಂದರೆ, $ab=q$ ಮತ್ತು $a+b=p$ ಆಗಿರಬೇಕು. ನಂತರ, ಮಧ್ಯದ ಪದ $px$ ಅನ್ನು $ax+bx$ ಎಂದು ವಿಭಜಿಸಿ, ಮರುಗುಂಪು ಮಾಡುವ ವಿಧಾನದಿಂದ ಅಪವರ್ತಿಸಬಹುದು.",
    "definitions": [],
    "formulas": [
      {
        "formula_name": "Identity IV",
        "latex": "(x+a)(x+b) = x^2 + (a+b)x + ab",
        "condition": "",
        "exception": "",
        "derived_from": "",
        "used_in": "$x^2+px+q$ ರೂಪದ ತ್ರಿಪದಗಳನ್ನು ಅಪವರ್ತಿಸಲು, ಇಲ್ಲಿ $p=a+b$ ಮತ್ತು $q=ab$.",
        "derivation": []
      }
    ],
    "theorems": [],
    "properties": [],
