  "theory": {
    "concept_summary": "ಈ ಅವಧಾರಣೆಯು ಪೂರ್ಣಾಂಕ ಘಾತಸೂಚಿಗಳಿಗೆ ಅನ್ವಯವಾಗುವ ಘಾತಾಂಕಗಳ ನಿಯಮಗಳನ್ನು ಭಾಗಲಬ್ಧ ಘಾತಸೂಚಿಗಳಿಗೂ ವಿಸ್ತರಿಸುತ್ತದೆ. $a^0$, $a^{-n}$, ಮತ್ತು $a^{p/q}$ ನಂತಹ ಪದಗಳ ಅರ್ಥವನ್ನು ವ್ಯಾಖ್ಯಾನಿಸುತ್ತದೆ ಮತ್ತು ಅವುಗಳನ್ನು ಬಳಸಿ ಅಭಿವ್ಯಕ್ತಿಗಳನ್ನು ಸಂಕ್ಷೇಪಿಸುವ ವಿಧಾನಗಳನ್ನು ವಿವರಿಸುತ್ತದೆ.",
    "definitions": [
      {
        "term": "ಘಾತಾಂಕದ ವ್ಯಾಖ್ಯೆಗಳು (Definitions of Exponents)",
        "definition": "a > 0 ಒಂದು ವಾಸ್ತವ ಸಂಖ್ಯೆ, m ಮತ್ತು n ಗಳು ಪೂರ್ಣಾಂಕಗಳು, n > 0 ಆಗಿರಲಿ."
      },
      {
        "term": "$a^0$",
        "definition": "$a^0 = 1$"
      },
      {
        "term": "$a^{-n}$",
        "definition": "$a^{-n} = \\frac{1}{a^n}$"
      },
      {
        "term": "$a^{\\frac{1}{n}}$",
        "definition": "$a^{\\frac{1}{n}} = \\sqrt[n]{a}$ (a ಯ n ನೇ ಮೂಲ)"
      },
      {
        "term": "$a^{\\frac{m}{n}}$",
        "definition": "$a^{\\frac{m}{n}} = (\\sqrt[n]{a})^m = \\sqrt[n]{a^m}$"
      }
    ],
    "formulas": [
      {
        "formula_name": "Product Rule",
        "latex": "a^p \\cdot a^q = a^{p+q}",
        "condition": "a > 0 ಒಂದು ವಾಸ್ತವ ಸಂಖ್ಯೆ ಮತ್ತು p, q ಗಳು ಭಾಗಲಬ್ಧ ಸಂಖ್ಯೆಗಳು",
        "exception": "",
        "derived_from": "",
        "used_in": "",
        "derivation": []
      },
      {
        "formula_name": "Power of a Power Rule",
        "latex": "(a^p)^q = a^{pq}",
        "condition": "a > 0 ಒಂದು ವಾಸ್ತವ ಸಂಖ್ಯೆ ಮತ್ತು p, q ಗಳು ಭಾಗಲಬ್ಧ ಸಂಖ್ಯೆಗಳು",
        "exception": "",
        "derived_from": "",
        "used_in": "",
        "derivation": []
      },
      {
        "formula_name": "Quotient Rule",
        "latex": "\\frac{a^p}{a^q} = a^{p-q}",
        "condition": "a > 0 ಒಂದು ವಾಸ್ತವ ಸಂಖ್ಯೆ ಮತ್ತು p, q ಗಳು ಭಾಗಲಬ್ಧ ಸಂಖ್ಯೆಗಳು",
        "exception": "",
        "derived_from": "",
        "used_in": "",
        "derivation": []
      },
      {
        "formula_name": "Power of a Product Rule",
        "latex": "a^p b^p = (ab)^p",
